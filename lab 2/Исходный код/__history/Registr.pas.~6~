Unit Registr;

Interface

Uses
    System.SysUtils;

Function GenirateKey(Seed: String): String;

Implementation

Function GenirateKey(Seed: String): String;
Var
    Temp, I: Integer;
    Current, Key: String;
Begin
    Key := '';
    Current := Seed;
    Repeat
        Key := Key + Current[1];
        Temp := (Ord(Current[28]) - Ord('0')) Xor (Ord(Current[3]) - Ord('0')) Xor (Ord(Current[1]) - Ord('0'));
        For I := 1 To Length(Current) - 1 Do
            Current[I] := Current[I + 1];
        Current[28] := Char(Ord('0') + Temp);
    Until Seed = Current;
End;

End.
