unit Registr;

interface

Uses
    System.SysUtils;

implementation

Function GenirateKey(Seed: String): String;
Var
    Temp, I: Integer;
    Current, Key: String;
Begin
    Key := '';
    Current := Seed;
    repeat
        Temp := StrToInt(Current[1]) xor StrToInt(Current[3]) xor StrToInt(Current[1]);
        Key := Key + Current[1];
        For I := 1 To Length(Current) - 1 Do
            Current[I] := Current[I+1];
        Current[28] := Char(Ord('0') + Temp);
    until seed <> current;

End;

end.
