{$R *.dfm}

Function ParseString(Memo: TMemo): String;
Var
    I: Integer;
Begin
    Result := '';
    For I := 1 To Length(Memo.Text) Do
    Begin
        If MainForm.DetimationMethod Then
        Begin
            If Memo.Text[I] In ['A' .. 'Z', 'a' .. 'z', ' ', #13, #10, #9] Then
                Result := Result + Memo.Text[I];
        End
        Else
        Begin
            If Check(Memo.Text[I], LOWER) Or Check(Memo.Text[I], UPPER) Or (Memo.Text[I] In [' ', #13, #10, #9]) Then
                Result := Result + Memo.Text[I];
        End;
    End;
End;

Function ParseKey(Edit: TEdit): String;
Var
    I: Integer;
    InputString: String;
Begin
    Result := '';
    InputString := Edit.Text;
    For I := 1 To Length(InputString) Do
    Begin
        IF MainForm.DetimationMethod Then
        Begin
            If InputString[I] In ['0' .. '9'] Then
                Result := Result + InputString[I];
        End
        Else
        Begin
            If Check(InputString[I], LOWER) Or Check(InputString[I], UPPER) Then
                Result := Result + UpCase(InputString[I]);

        End;
    End;
End;

Procedure TForm2.DecreepButtonClick(Sender: TObject);
Var
    Key, Str: String;
Begin
    Key := ParseKey(Edit1);
    Str := ParseString(Memo1);
    MemoResult.Lines.Clear;
    If MainForm.DetimationMethod Then
    Begin
        If (Key <> '') And AreCoprime(StrToInt(Key), 26) Then
            MemoResult.Text := DetimationDecryption(Str, Key);
    End
    Else
    Begin
        If Key <> '' Then
            MemoResult.Text := VigenereDecrypt(Str, Key);
    End;
End;

Procedure TForm2.EditOnChange(Sender: TObject);
Begin
    MemoResult.Lines.Clear;
    If (Memo1.Text = '') Or (Edit1.Text = '') Then
    Begin
        EncrypButton.Enabled := False;
        DecreepButton.Enabled := False;
    End
    Else
    Begin
        EncrypButton.Enabled := True;
        DecreepButton.Enabled := True;
    End;
End;

Procedure TForm2.EncrypButtonClick(Sender: TObject);
Var
    Key, Str: String;
Begin
    Key := ParseKey(Edit1);
    Str := ParseString(Memo1);
    MemoResult.Lines.Clear;
    If MainForm.DetimationMethod Then
    Begin
        If (Key <> '') And AreCoprime(StrToInt(Key), 26) Then
            MemoResult.Text := DetimationEncryption(Str, Key);
    End
    Else
    Begin
        If Key <> '' Then
            MemoResult.Text := VigenereEncrypt(Str, Key);
    End;

End;

procedure TForm2.OpenFile(Sender: TObject);
Var
    FileName: String;
    FileStream: TFileStream;
    StreamReader: TStreamReader;
begin
    If OpenTextFileDialog.Execute Then
    BEgin
        FileName := OpenTextFileDialog.FileName;
        FileStream := TFileStream.Create(FileName, fmOpenRead or fmShareDenyWrite);
        StreamReader := TStreamReader.Create(FileStream, TEncoding.UTF8, True);
        Memo1.Lines.Clear;
        Memo1.Lines.Text := StreamReader.ReadToEnd;
        MemoResult.Lines.Clear;
    End;

end;

End.
